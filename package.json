{
	"name": "@collab-list/root",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"author": "Mateusz Matysiak",
	"engines": {
		"node": "22.x",
		"pnpm": "9.15.0"
	},
	"packageManager": "pnpm@9.15.0",
	"scripts": {
		"dev:backend": "pnpm -C apps/backend dev",
		"dev:mobile": "pnpm -C apps/mobile start",
		"prod:backend": "pnpm -C apps/backend start",
		"prod:mobile": "pnpm -C apps/mobile start:prod",
		"typecheck": "pnpm --recursive run typecheck",
		"lint": "biome check --write .",
		"format": "biome format --write .",
		"db:generate": "pnpm -C apps/backend db:generate",
		"db:migrate": "pnpm -C apps/backend db:migrate",
		"db:seed": "pnpm -C apps/backend db:seed",
		"db:studio": "pnpm -C apps/backend db:studio",
		"knip": "knip",
		"test": "pnpm -C apps/backend test",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json}": [
			"biome check --write"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@types/node": "22.16.0",
		"dotenv": "17.2.3",
		"husky": "9.1.7",
		"knip": "6.0.1",
		"lint-staged": "16.4.0",
		"typescript": "5.9.3"
	}
}
